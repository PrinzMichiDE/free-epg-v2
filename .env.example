# Database
DATABASE_URL=postgresql://freeepg:freeepg@postgres:5432/freeepg

# Redis
REDIS_URL=redis://redis:6379

# EPG storage
EPG_DATA_DIR=/data/epg

# Admin (NextAuth)
ADMIN_EMAIL=admin@free-epg.de
ADMIN_PASSWORD=change-me-in-production
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://free-epg.de

# Analytics
ANALYTICS_ENABLED=true

# Worker cron (cron expression)
CRON_COUNTRY_FETCH=0 */6 * * *
CRON_IPTV_ORG_GRAB=0 2 * * *
CRON_ANALYTICS_AGG=0 2 * * *
CRON_ANALYTICS_CLEANUP=0 3 * * 0

# Docker Hub (prod)
DOCKERHUB_USER=freeepg
IMAGE_TAG=latest
