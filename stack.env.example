# Production stack configuration (copy to stack.env)
# Usage:
#   docker compose --env-file stack.env -f docker-compose.prod.yml pull
#   docker compose --env-file stack.env -f docker-compose.prod.yml up -d

# Docker Hub images
DOCKERHUB_USER=freeepg
IMAGE_TAG=latest

# PostgreSQL — password must match DATABASE_URL
POSTGRES_PASSWORD=change-me-in-production

# Database (host must be the compose service name)
DATABASE_URL=postgresql://freeepg:change-me-in-production@postgres:5432/freeepg

# Redis
REDIS_URL=redis://redis:6379

# EPG storage (path inside containers)
EPG_DATA_DIR=/data/epg

# Admin (NextAuth)
ADMIN_EMAIL=admin@free-epg.de
ADMIN_PASSWORD=change-me-in-production
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://free-epg.de

# Analytics
ANALYTICS_ENABLED=true

# Worker
SEED_ON_START=true
FETCH_ON_START=true
CRON_COUNTRY_FETCH=0 */6 * * *
CRON_IPTV_ORG_GRAB=0 2 * * *
CRON_ANALYTICS_AGG=0 2 * * *
CRON_ANALYTICS_CLEANUP=0 3 * * 0
CRON_M3U_CLEANUP=15 3 * * *
